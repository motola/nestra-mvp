# Copy this file to .env and fill in the values.
# Never commit .env — it is gitignored.

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (Docker Compose): postgresql+asyncpg://alphacon:alphacon@localhost:5432/alphacon_dev
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/alphacon_dev

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local dev (Docker Compose): redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ── Security ──────────────────────────────────────────────────────────────────
# Required in production (debug=False). Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-secure-random-value

# ── App mode ──────────────────────────────────────────────────────────────────
# Set to True locally to enable /docs, /redoc, and /openapi.json.
# Must be False (or unset) in production.
DEBUG=True

# ── Demo: LIFX ────────────────────────────────────────────────────────────────
# Personal access token from https://cloud.lifx.com/settings
LIFX_API_TOKEN=

# ── Demo: Govee ───────────────────────────────────────────────────────────────
# API key from Govee app → Profile → About Us → Apply for API Key
GOVEE_API_KEY=
